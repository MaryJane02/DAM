<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="android:windowBackground">@drawable/dark_background</item>
        <item name="colorPrimary">@color/my_dark_primary</item>
        <item name="colorSecondary">@color/my_dark_secondary</item>
        <item name="android:textColor">@color/my_dark_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ThemeOverlay.App.Button.TextButton" parent="">
        <item name="colorPrimary">@color/my_light_primary</item>
    </style>

    <style name="Theme.Night" parent="Theme.MyApplication">

    </style>
    <style name="Theme.Night.Land" parent="Theme.MyApplication">
        <item name="android:windowBackground">@drawable/dark_background_land</item>
    </style>
</resources>